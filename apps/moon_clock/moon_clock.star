load("encoding/base64.star", "base64")
load("encoding/json.star", "json")
load("math.star", "math")
load("render.star", "render")
load("sunrise.star", "sunrise")
load("time.star", "time")

# --- IMAGE DATA --- 30 different images of the moon in BASE64 format
MOON_PHASES = [
    "",  # 01_New_Moon.png
    "",  # 02_Waxing_Crescent.png
    "",  # 03_Waxing_Crescent.png
    "",  # 04_Waxing_Crescent.png
    "",  # 05_Waxing_Crescent.png
    "",  # 06_Waxing_Crescent.png
    "",  # 07_Waxing_Crescent.png
    "",  # 08_First_Quarter.png
    "",  # 09_Waxing_Gibbous.png
    "",  # 10_Waxing_Gibbous.png
    "",  # 11_Waxing_Gibbous.png
    "",  # 12_Waxing_Gibbous.png
    "",  # 13_Waxing_Gibbous.png
    "",  # 14_Waxing_Gibbous.png
    "",  # 15_Full_Moon.png
    "",  # 16_Waning_Gibbous.png
    "",  # 17_Waning_Gibbous.png
    "",  # 18_Waning_Gibbous.png
    "",  # 19_Waning_Gibbous.png
    "",  # 20_Waning_Gibbous.png
    "",  # 21_Waning_Gibbous.png
    "",  # 22_Waning_Gibbous.png
    "",  # 23_Last_Quarter.png
    "",  # 24_Waning_Crescent.png
    "",  # 25_Waning_Crescent.png
    "",  # 26_Waning_Crescent.png
    "",  # 27_Waning_Crescent.png
    "",  # 28_Waning_Crescent.png
    "",  # 29_Waning_Crescent.png
    "",  # 30_New_Moon.png
]

# --- MAIN CODE SECTION ---

def get_dynamic_moon_data(now, timezone_str):
    REFERENCE_NEW_MOON = 1768776720
    LUNAR_CYCLE = 2551442.877

    diff = now.unix - REFERENCE_NEW_MOON
    phase_float = (diff % LUNAR_CYCLE) / LUNAR_CYCLE

    total_images = len(MOON_PHASES)
    image_index = 0
    if total_images > 0:
        image_index = int((phase_float * total_images)) % total_images

    illum_val = (1 - math.cos(phase_float * 2 * 3.14159)) / 2
    illumination_pct = int(illum_val * 100)

    cycles_to_new = 1.0 - phase_float
    cycles_to_full = 0.5 - phase_float
    if cycles_to_full < 0:
        cycles_to_full += 1.0

    # Midnight Buffer: Subtract 12 hours (43200 seconds) to center the calendar day
    sec_to_new = (cycles_to_new * LUNAR_CYCLE) - 43200
    sec_to_full = (cycles_to_full * LUNAR_CYCLE) - 43200

    # Apply the specific timezone to prevent UTC leakage during formatting
    next_new_time = (now + time.parse_duration("%ds" % int(sec_to_new))).in_location(timezone_str)
    next_full_time = (now + time.parse_duration("%ds" % int(sec_to_full))).in_location(timezone_str)

    return {
        "index": image_index,
        "illumination": illumination_pct,
        "next_new_str": next_new_time.format("01/02"),
        "next_full_str": next_full_time.format("01/02"),
    }

def main(config):
    # Dynamic Timezone
    timezone = config.get("timezone") or "America/Los_Angeles"
    now = time.now().in_location(timezone)

    # Dynamic Location (lat/lng for Sunrise/Sunset calculation)
    lat, lng = 45.42, -122.77  # Default
    loc_str = config.get("location")
    if loc_str:
        loc_data = json.decode(loc_str)
        lat = float(loc_data.get("lat", lat))
        lng = float(loc_data.get("lng", lng))

    # Calculate Day/Night colors using the sunrise module
    s_rise = sunrise.sunrise(lat, lng, now)
    s_set = sunrise.sunset(lat, lng, now)

    is_night = now.unix < s_rise.unix or now.unix >= s_set.unix

    if is_night:
        c_time, illum_text_color, moon_overlay = "#FF0000", "#FFC107", "#00000080"
    else:
        c_time, illum_text_color, moon_overlay = "#00FF00", "#FFC107", "#00000033"

    # Get Moon Phase Data
    data = get_dynamic_moon_data(now, timezone)
    idx = data["index"]

    if len(MOON_PHASES) > 0:
        if idx >= len(MOON_PHASES):
            idx = 0
        img_str = MOON_PHASES[idx]
        image_data = base64.decode(img_str)
        img_widget = render.Image(src = image_data, width = 32, height = 32)
    else:
        img_widget = render.Box(width = 32, height = 32, color = "#222")

    time_str = now.format("03:04")
    illum_str = str(data["illumination"]) + "%"

    return render.Root(
        child = render.Row(
            expanded = True,
            main_align = "start",
            cross_align = "center",
            children = [
                render.Stack(
                    children = [
                        img_widget,
                        render.Box(width = 32, height = 32, color = moon_overlay),
                        render.Box(
                            width = 32,
                            height = 32,
                            child = render.Text(content = illum_str, color = illum_text_color, font = "6x13"),
                        ),
                    ],
                ),
                render.Box(width = 1, height = 1),
                render.Column(
                    main_align = "center",
                    cross_align = "end",
                    expanded = True,
                    children = [
                        render.Text(content = time_str, color = c_time, font = "6x13"),
                        render.Box(width = 1, height = 2),
                        render.Row(
                            main_align = "end",
                            expanded = True,
                            children = [
                                render.Text(content = "F:", color = "#FFA500", font = "tb-8"),
                                render.Text(content = data["next_full_str"], color = "#00CCFF", font = "tb-8"),
                            ],
                        ),
                        render.Row(
                            main_align = "end",
                            expanded = True,
                            children = [
                                render.Text(content = "N:", color = "#FFA500", font = "tb-8"),
                                render.Text(content = data["next_new_str"], color = "#00CCFF", font = "tb-8"),
                            ],
                        ),
                    ],
                ),
            ],
        ),
    )
